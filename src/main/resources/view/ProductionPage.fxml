<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1343.0" style="-fx-background-color: #fae9f5;" stylesheets="@../css/main.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.pearlgims.controller.ProductionPageController">
   <children>
      <TabPane prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <tabs>
          <Tab text="Production">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <Label prefHeight="27.0" prefWidth="122.0" text="Production" textFill="#772450">
                           <font>
                              <Font name="Cambria Bold" size="22.0" />
                           </font>
                        </Label>
                     </children>
                  </AnchorPane>
            </content>
          </Tab>
          <Tab text="Issued Raw Materials">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
            </content>
          </Tab>
            <Tab text="Issue Raw Materials">
               <content>
                  <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <AnchorPane prefHeight="691.0" prefWidth="348.0" style="-fx-background-color: #cdd9f0; -fx-background-radius: 20px;">
                           <children>
                              <BorderPane prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
                                 <top>
                                    <Pane prefHeight="175.0" prefWidth="308.0" BorderPane.alignment="CENTER">
                                       <children>
                                          <Label alignment="CENTER" contentDisplay="CENTER" layoutX="74.0" text="Issue Details">
                                             <font>
                                                <Font name="System Bold" size="25.0" />
                                             </font>
                                          </Label>
                                          <ImageView fitHeight="113.0" fitWidth="201.0" layoutX="81.0" layoutY="54.0" pickOnBounds="true" preserveRatio="true">
                                             <image>
                                                <Image url="@../images/orderImage.png" />
                                             </image>
                                             <cursor>
                                                <Cursor fx:constant="HAND" />
                                             </cursor>
                                          </ImageView>
                                       </children>
                                    </Pane>
                                 </top>
                                 <center>
                                    <VBox alignment="CENTER" prefHeight="358.0" prefWidth="308.0" spacing="20.0" BorderPane.alignment="CENTER">
                                       <children>
                                          <HBox spacing="10.0">
                                             <children>
                                                <Label prefHeight="16.0" prefWidth="120.0" text="Raw Material Id">
                                                   <font>
                                                      <Font name="SansSerif Bold" size="16.0" />
                                                   </font>
                                                </Label>
                                                <Label fx:id="lblRawMaterialId" text="1">
                                                   <font>
                                                      <Font name="SansSerif Regular" size="14.0" />
                                                   </font>
                                                </Label>
                                             </children>
                                          </HBox>
                                          <HBox>
                                             <children>
                                                <Label prefHeight="16.0" prefWidth="120.0" text="Issue Date">
                                                   <font>
                                                      <Font name="SansSerif Bold" size="16.0" />
                                                   </font>
                                                </Label>
                                                <Label fx:id="lblIssueDate" layoutX="110.0" layoutY="10.0" text="2026-01-01">
                                                   <font>
                                                      <Font name="SansSerif Regular" size="14.0" />
                                                   </font>
                                                </Label>
                                             </children>
                                          </HBox>
                                          <HBox layoutX="10.0" layoutY="400.0">
                                             <children>
                                                <Label prefHeight="16.0" prefWidth="120.0" text="Qty">
                                                   <font>
                                                      <Font name="SansSerif Bold" size="16.0" />
                                                   </font>
                                                </Label>
                                                <TextField fx:id="txtIssueQty" HBox.hgrow="ALWAYS">
                                                   <font>
                                                      <Font name="SansSerif Regular" size="14.0" />
                                                   </font>
                                                </TextField>
                                             </children>
                                          </HBox>
                                       </children>
                                    </VBox>
                                 </center>
                                 <bottom>
                                    <Pane prefHeight="92.0" prefWidth="308.0" BorderPane.alignment="CENTER">
                                       <children>
                                          <Button layoutX="52.0" layoutY="11.0" onAction="#btnIssueRawMaterialsOnAction" prefHeight="35.0" prefWidth="141.0" style="-fx-background-color: #772450;" text="Issue Raw Materials" textFill="WHITE">
                                             <font>
                                                <Font name="SansSerif Bold" size="12.0" />
                                             </font>
                                          </Button>
                                          <Button layoutX="205.0" layoutY="30.0" onAction="#btnResetOnAction" prefHeight="35.0" prefWidth="75.0" style="-fx-background-color: #772450;" text="Reset" textFill="WHITE">
                                             <font>
                                                <Font name="SansSerif Bold" size="12.0" />
                                             </font>
                                          </Button>
                                       </children>
                                    </Pane>
                                 </bottom>
                              </BorderPane>
                           </children>
                        </AnchorPane>
                     </children>
                  </AnchorPane>
               </content>
            </Tab>
            <Tab text="Quality Check">
               <content>
                  <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
               </content>
            </Tab>
        </tabs>
      </TabPane>
   </children>
</AnchorPane>
